# Goodwin Bricklaying — environment variables
# Copy to .env.local and fill in once the client supplies the values.
# All NEXT_PUBLIC_* values are exposed to the browser at build time.

# Google Analytics 4 measurement ID (e.g. G-XXXXXXXXXX).
# Leave blank to keep analytics fully disabled. When set, GA4 only loads
# after the visitor accepts analytics cookies in the consent banner.
NEXT_PUBLIC_GA_ID=

# Contact / enquiry form endpoint (e.g. GoHighLevel form POST URL).
# Leave blank to run the form in demo mode (shows the success state
# without sending anywhere). When set, submissions POST here as JSON.
NEXT_PUBLIC_ENQUIRY_ENDPOINT=
